# AWS Region
AWS_REGION=us-east-1

# LocalStack (dev only)
AWS_ENDPOINT=http://localhost:4566

# S3 Buckets
S3_STAGING_BUCKET=s3-staging-uploads
S3_PROCESSING_BUCKET=s3-processing-uploads
S3_QUARANTINE_BUCKET=s3-quarantine
S3_OUTPUT_BUCKET=s3-output-certificates

# SQS
SQS_ANALYSIS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/analysis-queue

# Step Functions
SFN_STATE_MACHINE_ARN=arn:aws:states:us-east-1:000000000000:stateMachine:AnalysisPipeline

# DynamoDB Tables
DYNAMO_ANALYSES_TABLE=analyses
DYNAMO_CERTIFICATES_TABLE=certificates

# Auth0 (JWT verification)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.your-platform.com

# Presigned URL TTL (seconds)
PRESIGNED_URL_TTL_UPLOAD=900
PRESIGNED_URL_TTL_DOWNLOAD=60

# Environment
NODE_ENV=development
LOG_LEVEL=info
